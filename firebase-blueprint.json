{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "displayName": { "type": "string", "description": "User's display name from provider." },
        "nickname": { "type": "string", "description": "User's chosen nickname." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user account was created." }
      },
      "required": ["uid", "email"]
    },
    "Session": {
      "title": "Chat Session",
      "description": "A single conversation thread.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Session ID." },
        "title": { "type": "string", "description": "Title of the conversation." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last time the session was updated." },
        "userId": { "type": "string", "description": "Owner of the session." }
      },
      "required": ["id", "title", "updatedAt", "userId"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Message ID." },
        "role": { "type": "string", "enum": ["user", "assistant"], "description": "Who sent the message." },
        "content": { "type": "string", "description": "Text content of the message." },
        "imageUrl": { "type": "string", "description": "Optional image generated by AI." },
        "attachedImageUrl": { "type": "string", "description": "Optional image attached by user." },
        "attachedAudioUrl": { "type": "string", "description": "Optional audio attached by user." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["id", "role", "content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document."
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Chat session metadata."
    },
    "/users/{userId}/sessions/{sessionId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a session."
    }
  }
}
