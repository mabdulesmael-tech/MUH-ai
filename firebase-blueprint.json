{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID from Firebase Auth." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile photo URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user first registered." },
        "lastLogin": { "type": "string", "format": "date-time", "description": "When the user last logged in." }
      },
      "required": ["uid", "email", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profile information, keyed by their Firebase Auth UID."
    }
  }
}
